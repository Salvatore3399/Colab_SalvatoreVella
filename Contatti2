class Contatto:
  def __init__(self, nome, cognome, telefono, email):
    self.nome = nome
    self.cognome = cognome
    self.telefono = telefono
    self.email = email

  def __str__(self):
    return f"{self.nome} {self.cognome} | {self.telefono} | {self.email}"

  def __repr__(self):
    return f"Contatto('{self.nome}', '{self.cognome}', '{self.telefono}', '{self.email}')"

  def __eq__(self, other):
    if not isinstance(other, Contatto):
      return NotImplemented
    return self.nome == other.nome and self.cognome == other.cognome and self.telefono == other.telefono

  def nome_completo(self):
    return f"{self.nome} {self.cognome}"

# Esempi di utilizzo della classe Contatto:
contatto1 = Contatto('Mario', 'Rossi', '333-1234567', 'mario@email.it')
contatto2 = Contatto('Luigi', 'Verdi', '333-7654321', 'luigi@email.it')
contatto3 = Contatto('Mario', 'Rossi', '333-1234567', 'mario.r@email.it') # Stesso nome, cognome, telefono ma email diversa

print("--- Test della classe Contatto ---")
print(f"Contatto 1 (str): {contatto1}")
print(f"Contatto 2 (repr): {repr(contatto2)}")
print(f"Nome completo Contatto 1: {contatto1.nome_completo()}")

print(f"Contatto 1 è uguale a Contatto 3? (stesso nome, cognome, telefono): {contatto1 == contatto3}")
print(f"Contatto 1 è uguale a Contatto 2?: {contatto1 == contatto2}")
