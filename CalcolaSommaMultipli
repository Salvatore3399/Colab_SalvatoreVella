def calculate_sum_multiples(n):
  total_sum = 0  # Initialize a variable to store the sum
  i = 0
  # Loop from 0 up to (but not including) n
  while (i < n):
    if (i % 3) == 0 or (i % 5) == 0:
      total_sum += i  # Add the number to the total sum if it's a multiple of 3 or 5
    i += 1
  return total_sum

# Test the function with n=10
print(calculate_sum_multiples(1000)) # Expected: 0 + 3 + 5 + 6 + 9 = 23
