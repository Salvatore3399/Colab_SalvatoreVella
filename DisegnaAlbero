def disegna_albero_natale(altezza):
    # Disegna la chioma dell'albero
    for i in range(altezza):
        # Calcola gli spazi per centrare
        spazi = ' ' * (altezza - i - 1)
        # Calcola gli asterischi (numero dispari: 1, 3, 5...)
        asterischi = '*' * (2 * i + 1)
        print(spazi + asterischi)

    # Disegna il tronco (centrato)
    tronco = ' ' * (altezza - 1) + '|'
    print(tronco)

disegna_albero_natale(5)
